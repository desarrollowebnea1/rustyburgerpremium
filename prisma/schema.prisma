// RustyBurger — modelos de negocio (Fase 14A)
// DATABASE_URL en .env.local — ver .env.example

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum AdminRole {
  OWNER
  ADMIN
  STAFF
}

enum DeliveryType {
  DELIVERY
  TAKEAWAY
}

enum PaymentMethod {
  CASH
  TRANSFER
  CARD
  IFOOD
  OTHER
}

enum OrderStatus {
  RECEIVED
  CONFIRMED
  PREPARING
  READY
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum OrderSource {
  WEB
  WHATSAPP
  ADMIN
}

model AdminUser {
  id           String    @id @default(cuid())
  name         String?
  email        String    @unique
  passwordHash String
  role         AdminRole @default(OWNER)
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  imageUrl    String?
  sortOrder   Int       @default(0)
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]

  @@index([active, sortOrder])
}

model Product {
  id               String      @id @default(cuid())
  categoryId       String?
  category         Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  name             String
  slug             String      @unique
  description      String
  shortDescription String?
  price            Decimal     @db.Decimal(10, 2)
  compareAtPrice   Decimal?    @db.Decimal(10, 2)
  imageUrl         String?
  badge            String?
  active           Boolean     @default(true)
  available        Boolean     @default(true)
  featured         Boolean     @default(false)
  sortOrder        Int         @default(0)
  ingredients      String?
  allergens        String?
  tags             Json?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  orderItems       OrderItem[]

  @@index([active, available, featured, sortOrder])
}

model Promo {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  tagline     String?
  description String?
  price       Decimal?  @db.Decimal(10, 2)
  imageUrl    String?
  active      Boolean   @default(true)
  startsAt    DateTime?
  endsAt      DateTime?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([active, sortOrder])
}

model Order {
  id            String        @id @default(cuid())
  code          String        @unique
  customerName  String
  customerPhone String
  customerEmail String?
  deliveryType  DeliveryType
  address       String?
  notes         String?
  paymentMethod PaymentMethod @default(CASH)
  status        OrderStatus   @default(RECEIVED)
  subtotal      Decimal       @db.Decimal(10, 2)
  deliveryFee   Decimal       @default(0) @db.Decimal(10, 2)
  discount      Decimal       @default(0) @db.Decimal(10, 2)
  total         Decimal       @db.Decimal(10, 2)
  source        OrderSource   @default(WEB)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  items         OrderItem[]

  @@index([code])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id              String   @id @default(cuid())
  orderId         String
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId       String?
  product         Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productName     String
  quantity        Int
  unitPrice       Decimal  @db.Decimal(10, 2)
  total           Decimal  @db.Decimal(10, 2)
  notes           String?
  selectedOptions Json?
  createdAt       DateTime @default(now())
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
}

model ImageAsset {
  id        String   @id @default(cuid())
  url       String
  pathname  String?
  alt       String?
  type      String?
  createdAt DateTime @default(now())
}
