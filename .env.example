# DATABASE_URL — conexión PostgreSQL / Neon
DATABASE_URL="postgresql://user:password@host.neon.tech/rustyburger?sslmode=require"

# JWT_SECRET — obligatorio para login admin (string largo y aleatorio)
JWT_SECRET="change-me-in-production-use-long-random-string"

# ADMIN_EMAIL / ADMIN_PASSWORD — admin inicial del seed (opcional)
ADMIN_EMAIL="admin@rustyburger.com"
ADMIN_PASSWORD="change-me-strong-password"

# NEXT_PUBLIC_APP_URL — URL pública del sitio
NEXT_PUBLIC_APP_URL="http://localhost:3001"

# WhatsApp pedidos
NEXT_PUBLIC_WHATSAPP_NUMBER="5547984062460"
NEXT_PUBLIC_WHATSAPP_MESSAGE="Olá! Quero pedir no Rusty Burger"

# BLOB_READ_WRITE_TOKEN — Token de Vercel Blob para subir imágenes desde el panel admin.
# Crear Blob Store en Vercel → Storage → copiar token → pegar aquí y en Production env.
BLOB_READ_WRITE_TOKEN=""
